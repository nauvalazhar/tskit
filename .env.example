# =============================================================================
# TSKit — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit the .env file — it contains secrets.

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
VITE_APP_URL=http://localhost:3000
VITE_APP_NAME=TSKit

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:@localhost:5432/tskit

# -----------------------------------------------------------------------------
# Auth (Better Auth)
# -----------------------------------------------------------------------------
# Generate a random secret: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Social Login — GitHub
# -----------------------------------------------------------------------------
# Create an OAuth app: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Social Login — Google (optional)
# -----------------------------------------------------------------------------
# Create credentials: https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Email (Resend)
# -----------------------------------------------------------------------------
# Provider: "resend" (more drivers can be added in core/drivers/email/)
EMAIL_PROVIDER=resend
EMAIL_FROM=onboarding@resend.dev
# Get your API key: https://resend.com/api-keys
RESEND_API_KEY=

# -----------------------------------------------------------------------------
# Storage (Cloudflare R2 / S3-compatible)
# -----------------------------------------------------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
VITE_STORAGE_URL=

# -----------------------------------------------------------------------------
# Billing (Stripe)
# -----------------------------------------------------------------------------
# Dashboard: https://dashboard.stripe.com/test/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
# Webhook signing secret (from Stripe CLI or dashboard)
STRIPE_WEBHOOK_SECRET=
